---
interface Props {
    author?: string;
    authorLink?: string;
    authorIcon?: string;
    category?: string;
    platform?: string;
    platformLink?: string;
}

const { author, authorLink, authorIcon, category, platform, platformLink } = Astro.props;

const inferred = (() => {
    if (!platformLink) return { name: platform, icon: undefined as string | undefined };
    if (platformLink.includes('tryhackme.com')) return { name: 'TryHackMe', icon: 'lolf lol-tryhackme' };
    return { name: platform ?? 'Link', icon: 'fas fa-external-link-square-alt' };
})();
---

<style lang="scss">
.challenge-author {
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: 1rem;
    row-gap: 0.25rem;
    align-items: baseline;

    .ca-label {
        font-weight: 700;
        text-decoration: underline;
    }
    a {
        text-decoration: none;
    }
}
</style>

<div class="challenge-author my-2">
    <div class="ca-label">Author:</div>
    <div>
        {authorLink && author && (
            <a href={authorLink} target="_blank" rel="noopener">
                {authorIcon && <em class={authorIcon}></em>} {author}
            </a>
        )}
        {!authorLink && author && (<span>{author}</span>)}
        {!author && (<span>Unknown</span>)}
    </div>
    {category && (
        <>
            <div class="ca-label">Category:</div>
            <div>{category}</div>
        </>
    )}
    {platformLink && (
        <>
            <div class="ca-label">Link:</div>
            <div>
                <a href={platformLink} target="_blank" rel="noopener">
                    {inferred.icon && <em class={inferred.icon}></em>} {inferred.name}
                </a>
            </div>
        </>
    )}
</div>
<hr/>
