---
import { type CollectionEntry, render } from 'astro:content';
import WalkthroughLayout from '../../layouts/WalkthroughLayout.astro';
import { getPublishedWalkthroughs } from '../../utils/collections';

export async function getStaticPaths() {
	const walkthroughs = await getPublishedWalkthroughs();
	return walkthroughs.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'walkthroughs'>;

const post = Astro.props;
const { Content } = await render(post);
---

<WalkthroughLayout {...post.data}>
	<Content />
</WalkthroughLayout>
