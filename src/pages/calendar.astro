---
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { CalendarData } from '../data/calendar';
import ISOFormattedDate from '../components/stub/ISOFormattedDate.astro';
import MainBody from '../layouts/MainBody.astro';

const formatDate = (dateTime: Date) => dateTime.toISOString().split("T")[0];
let years = ((start: number, stop: number, step = 1) =>
  Array(Math.ceil((stop - start) / step)).fill(start).map((x, y) => x + y * step))(2024, (new Date()).getFullYear() + 1)
let now = new Date();
---

<MainBody title={`calendar | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
    <h1>~$ calendar</h1>

    <p>Find me here!</p>

    <h2>Upcoming events</h2>

    <ul>
        {CalendarData.filter( e => (e.endDate ?? e.startDate) > now && e.startDate.getFullYear() == now.getFullYear()).map( e => <li class="pb-1"><strong><ISOFormattedDate date={e.startDate} /></strong>{e.endDate && " - "}{e.endDate && <strong><ISOFormattedDate date={e.endDate} /></strong>}:<br /><em>{e.eventName}, {e.location}</em></li>)}
    </ul>

    <hr/>

    <h2>Past events</h2>

    {years.slice().reverse().map(year => (
        <>
            <h3>{year}</h3>

            <ul>
                {CalendarData.filter( e => (e.endDate ?? e.startDate) < now && e.startDate.getFullYear() == year).map( e => <li class="pb-1"><strong><ISOFormattedDate date={e.startDate} /></strong>{e.endDate && " - "}{e.endDate && <strong><ISOFormattedDate date={e.endDate} /></strong>}:<br /><em>{e.eventName}, {e.location}</em></li>)}
            </ul>
        </>
    ))}
</MainBody>
